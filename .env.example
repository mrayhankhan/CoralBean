# Optional — supplying a GitHub personal access token bumps your rate
# limit from 60 to 5,000 requests/hour. Read-only `public_repo` scope is
# enough. Without it the app still works on small repos.
GITHUB_TOKEN=

# Path to the coral binary. Default: `coral` on PATH.
CORAL_BIN=coral

# Optional — concurrency for the per-dependency Coral query fan-out.
# Lower this if you hit OSV/npm rate limits.
AUDIT_CONCURRENCY=6
